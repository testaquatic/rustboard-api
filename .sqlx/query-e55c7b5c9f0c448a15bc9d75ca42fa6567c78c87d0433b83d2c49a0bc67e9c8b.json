  "query": "\n            UPDATE posts\n            SET \n                title = COALESCE($1, title),\n                body = COALESCE($2, body), \n                updated_at = NOW()\n            WHERE id = $3\n            RETURNING id, title, body, author_id, created_at, updated_at\n            ",
