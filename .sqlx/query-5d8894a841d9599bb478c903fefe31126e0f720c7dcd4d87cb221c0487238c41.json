  "query": "\n            SELECT \n                id, post_id, (SELECT author_id FROM posts WHERE id = $1) AS \"post_author_id!\", body, created_at, updated_at\n            FROM comments\n            WHERE post_id = $1\n            ORDER BY created_at DESC, id DESC\n            ",
